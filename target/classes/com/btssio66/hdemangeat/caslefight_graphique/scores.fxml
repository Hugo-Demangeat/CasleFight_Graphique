<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.btssio66.hdemangeat.caslefight_graphique.controller.ScoresController">

    <!-- Top : Titre + total combats -->
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #021607ff; -fx-padding: 20;">
            <Label text="Statistiques des Combats" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
            <Label fx:id="totalCombatsLabel" text="Total de combats : 0" textFill="#ecf0f1">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- Center : TableView des scores -->
    <center>
        <TableView fx:id="scoresTableView" style="-fx-background-color: #ecf0f1;">
            <columns>
                <TableColumn fx:id="nomColumn" prefWidth="150.0" text="Personnage"/>
                <TableColumn fx:id="victoiresColumn" prefWidth="100.0" text="Victoires"/>
                <TableColumn fx:id="defaitesColumn" prefWidth="100.0" text="Défaites"/>
                <TableColumn fx:id="totalPVColumn" prefWidth="120.0" text="Total PV"/>
                <TableColumn fx:id="ratioColumn" prefWidth="130.0" text="Ratio V/D"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>

    <!-- Bottom : Boutons Actualiser et Fermer -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15;">
            <Button text="Actualiser" onAction="#refreshAction" 
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;">
                <font>
                    <Font name="System Bold" size="14.0"/>
                </font>
            </Button>
            <Button text="Fermer" onAction="#closeAction" 
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;">
                <font>
                    <Font name="System Bold" size="14.0"/>
                </font>
            </Button>
        </HBox>
    </bottom>

</BorderPane>
